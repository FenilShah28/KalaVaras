# ============================================================
# KalaVaras Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ---------- Application ----------
# "development" | "production" | "test"
NODE_ENV=development

# Port the API server listens on
API_PORT=4000

# Full URL where the React frontend is served (used for CORS whitelist)
FRONTEND_URL=http://localhost:5173

# ---------- Database (PostgreSQL 15) ----------
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/kalavaras

# ---------- Redis 7 ----------
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# ---------- JWT Secrets ----------
# IMPORTANT: Access and refresh secrets MUST be different.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Signs 15-minute access tokens
JWT_ACCESS_SECRET=replace_with_64_byte_hex_access_secret

# Signs 7-day refresh tokens (stored in httpOnly cookie)
JWT_REFRESH_SECRET=replace_with_64_byte_hex_refresh_secret

# ---------- Slit-Scan Microservice ----------
# Shared secret for internal service-to-service auth.
# The Python slit-scan service validates this header on every request.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_SECRET=replace_with_32_byte_hex_service_secret

# URL where the slit-scan Python service is running
SLIT_SCAN_SERVICE_URL=http://localhost:5000

# ---------- Cloudflare R2 (Media Storage) ----------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=kalavaras-media
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ---------- Email (Resend API) ----------
# Used for email verification and password reset
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@kalavaras.app

# ---------- Logging ----------
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=debug
